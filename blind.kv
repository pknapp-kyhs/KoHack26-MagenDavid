#:kivy 2.1.0
<Blind>:    
    # canvas:
    #     Rectangle: #center line
    #         pos: self.center_x, 0
    #         size: 10, self.height
            
    # Label: #file button
    #     font_size: 40  
    #     center_x: 40
    #     top: root.top - 10
    #     text: "File"
        
    # Label: 
    #     font_size: 70  
    #     center_x: root.width * 3 / 4
    #     top: root.top - 50
    #     text: "0"
    BoxLayout:
        orientation: 'vertical'
        center_x: root.width * 1 / 2
        top: root.top * 1/2
        Camera:
            id: camera
            resolution: (1080, 1920)
            play: True
            size_hint: (1, 1)

        Button:
            text: 'Capture'
            size_hint_y: None
            height: '48dp'
            on_release: app.capture_photo()
